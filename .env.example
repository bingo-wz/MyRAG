# 数据库
DATABASE_USERNAME=myrag
DATABASE_PASSWORD=change-me-database

# MinIO
MINIO_ACCESS_KEY=myrag-admin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=myrag-knowledge

# Milvus
MILVUS_TOKEN=root:Milvus
MILVUS_COLLECTION=myrag_chunks_v1

# OpenAI-compatible Embedding 服务，例如 BGE-M3 推理网关
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024

# 单机轻量环境保持 1；连接三节点以上 Kafka 集群时改为 3
KAFKA_REPLICATION_FACTOR=1
KAFKA_CONCURRENCY=1
OUTBOX_RETENTION_DAYS=7

# 中国大陆网络构建 OCR 镜像较慢时可取消注释
# UBUNTU_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu-ports
# MAVEN_MIRROR=https://maven.aliyun.com/repository/public
