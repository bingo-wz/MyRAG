# 数据库
DATABASE_USERNAME=myrag
DATABASE_PASSWORD=change-me-database

# MinIO
MINIO_ACCESS_KEY=myrag-admin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=myrag-knowledge

# Milvus
MILVUS_TOKEN=root:Milvus
MILVUS_COLLECTION=myrag_chunks_v1

# SiliconFlow Chat / Embedding，共用一个 API Key
SILICONFLOW_API_KEY=replace-with-siliconflow-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32

# 默认选择 SiliconFlow 当前免费的轻量模型，生产可按评测结果覆盖
CHAT_BASE_URL=https://api.siliconflow.cn/v1
CHAT_MODEL=Qwen/Qwen3-8B
CHAT_MAX_TOKENS=800
CHAT_MAX_ATTEMPTS=2
CHAT_ENABLE_THINKING=false
AI_HTTP_CONNECT_TIMEOUT_SECONDS=3
AI_HTTP_READ_TIMEOUT_SECONDS=60

# 文件解析硬超时
PARSE_TIMEOUT_SECONDS=120

# Milvus 索引每日自动对账；可通过管理员接口手工触发
VECTOR_RECONCILIATION_ENABLED=true
VECTOR_RECONCILIATION_CRON=0 30 3 * * *

# 单机轻量环境保持 1；连接三节点以上 Kafka 集群时改为 3
KAFKA_REPLICATION_FACTOR=1
KAFKA_CONCURRENCY=1
KAFKA_IMPORT_PARTITIONS=3
OUTBOX_RETENTION_DAYS=7

# 中国大陆网络构建 OCR 镜像较慢时可取消注释
# UBUNTU_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu-ports
# MAVEN_MIRROR=https://maven.aliyun.com/repository/public
